}

QWidget#centralwidget {
    background-color: qlineargradient(spread:pad, x1:0.5, y1:0, x2:0.5, y2:1, stop:0 #1a1d1a, stop:1 #050505);
}

QGroupBox {
    border: 1px solid #3a413a;
    border-radius: 4px;
    margin-top: 20px;
    background-color: rgba(20, 25, 20, 220);
    color: #c5a059;
    font-weight: bold;
    font-family: "Segoe UI Semibold";
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px;
}

QPushButton {
    background-color: #252a25;
    border: 1px solid #454d45;
    color: #e0e0e0;
    border-radius: 3px;
    padding: 8px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #353d35;
    border: 1px solid #c5a059;
}

QPushButton:pressed {
    background-color: #151815;
}

QLabel {
    color: #e0e0e0;
}

QLabel#resultLabel {
    background-color: #0f120f;
    border: 1px solid #2a302a;
    padding: 10px;
    color: #8da38d;
    font-family: "Consolas";
}
